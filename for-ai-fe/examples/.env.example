# OpenAI 兼容 API 配置
# 复制此文件为 .env.local 并填入你的配置

# API 基础地址（不带 /v1）
VITE_API_BASE_URL=https://api.deepseek.com

# API Key
VITE_API_KEY=sk-your-api-key-here

# 模型名称
VITE_MODEL=deepseek-chat

# ========== 其他服务商示例 ==========

# OpenAI
# VITE_API_BASE_URL=https://api.openai.com
# VITE_MODEL=gpt-4o-mini

# Moonshot (月之暗面)
# VITE_API_BASE_URL=https://api.moonshot.cn
# VITE_MODEL=moonshot-v1-8k

# 智谱 AI
# VITE_API_BASE_URL=https://open.bigmodel.cn/api/paas
# VITE_MODEL=glm-4-flash

# 通义千问
# VITE_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode
# VITE_MODEL=qwen-turbo

# Groq
# VITE_API_BASE_URL=https://api.groq.com/openai
# VITE_MODEL=llama-3.1-8b-instant

# 本地 Ollama
# VITE_API_BASE_URL=http://localhost:11434
# VITE_MODEL=llama3.2
